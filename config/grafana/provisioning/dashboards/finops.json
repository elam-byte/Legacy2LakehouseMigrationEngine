  "refresh": "30s",
  "schemaVersion": 38,
  "tags": ["migration", "lakehouse", "finops", "iceberg"],
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "Legacy-to-Lakehouse FinOps Dashboard",
  "uid": "legacy2lakehouse-finops",
